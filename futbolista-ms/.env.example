SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
PORT=3004
ALLOWED_ORIGIN=http://localhost:8081
# Base URL de equipos-ms: de ahí salen equipos, partidos y estadísticas.
EQUIPOS_API_URL=http://localhost:3002

# Bucket público de Supabase Storage donde se guardan las fotos de perfil.
SUPABASE_STORAGE_BUCKET=Perfil

# Credenciales S3 del bucket. La subida usa el SDK de Supabase con la
# service-role key, así que estas claves sólo hacen falta para herramientas
# externas compatibles con S3 (aws-cli, rclone, backups...).
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
