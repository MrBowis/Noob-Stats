# ============================================================
# Variables de la pila de Docker (docker-compose.yml).
# Copia este archivo a .env en el servidor y rellena los valores.
#   cp .env.example .env
# ============================================================

# ---- Supabase (compartido por los cuatro microservicios) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bucket público donde jugadores-ms guarda las fotos de perfil.
SUPABASE_STORAGE_BUCKET=Perfil

# ---- Red ----
# Puerto público del host. 80 en EC2; cámbialo si ya está ocupado.
HTTP_PORT=80

# Origen permitido por CORS en los microservicios. Como el frontend llama a
# través de la pasarela nginx (mismo origen), "*" es suficiente; si publicas
# un dominio, pon aquí su URL exacta.
ALLOWED_ORIGIN=*

# Esquema del deep link de Google OAuth en la app móvil.
EXPO_PUBLIC_AUTH_REDIRECT_SCHEME=noobstats

# ---- Observabilidad ----
# Nivel de log estructurado de los microservicios: error|warn|info|debug|verbose.
LOG_LEVEL=info

# Grafana. Es el único servicio de monitoreo con puerto publicado, protegido
# con estas credenciales. La contraseña es OBLIGATORIA (no hay valor por
# defecto). No pongas un valor real en este .env.example.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_PORT=3000
