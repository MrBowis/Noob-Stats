            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service) (rate(http_request_duration_seconds_sum{service=~\"$service\"}[5m])) / sum by (service) (rate(http_request_duration_seconds_count{service=~\"$service\"}[5m]))",
          "legendFormat": "{{service}}",
          "instant": false,
          "range": true,
          "refId": "A"
        }
      ]
    },
