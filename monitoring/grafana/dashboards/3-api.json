          },
          "expr": "sum(rate(http_requests_total{service=~\"$service\",status=~\"2..\"}[5m]))",
          "legendFormat": "2xx",
          "instant": false,
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
