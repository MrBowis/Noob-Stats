      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (name) (container_spec_memory_limit_bytes{name=~\"noobstats-.*\"} > 0)",
          "legendFormat": "{{name}}",
          "instant": false,
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
